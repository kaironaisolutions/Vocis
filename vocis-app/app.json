{
  "expo": {
    "name": "Vocis",
    "slug": "vocis-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "vocis",
    "owner": "kaironai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vocis.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Vocis needs microphone access to record voice inventory entries.",
        "NSSpeechRecognitionUsageDescription": "Vocis uses speech recognition to transcribe inventory items.",
        "NSFaceIDUsageDescription": "Vocis uses Face ID to protect your inventory data during export.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vocis.app",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": true
        }
      ],
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Vocis needs microphone access to record voice inventory entries."
        }
      ],
      "expo-mail-composer",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Vocis uses Face ID to protect your inventory data during export."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3482bf37-fed7-4d91-9a79-3757375937af"
      },
      "sttProxyUrl": "https://vocis-stt-proxy.kaironai.workers.dev",
      "router": {}
    },
    "runtimeVersion": "1.0.0"
  }
}
