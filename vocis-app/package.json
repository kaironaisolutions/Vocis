{
  "name": "vocis-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --omit=dev",
    "prebuild:check": "npm run typecheck && npm run test && npm run audit",
    "build:dev": "npx eas build --profile development --platform all",
    "build:preview": "npx eas build --profile preview --platform all",
    "build:production": "npx eas build --profile production --platform all",
    "submit:ios": "npx eas submit --platform ios --profile production",
    "submit:android": "npx eas submit --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^8.7.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-mail-composer": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.0",
    "jest": "~29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": ["@sentry/react-native"]
    }
  }
}
