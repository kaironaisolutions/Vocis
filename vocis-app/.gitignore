# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.*
.env*.local

# secrets / credentials
*.secret
credentials.json
google-services.json
GoogleService-Info.plist

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example

# Claude Code runtime locks (per-session, must not be tracked)
.claude/scheduled_tasks.lock
